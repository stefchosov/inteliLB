# ---- build stage ----
FROM golang:1.21-alpine AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" \
    -o /backend ./cmd/backend

# ---- runtime stage ----
FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /backend /backend
EXPOSE 8080
ENTRYPOINT ["/backend"]
